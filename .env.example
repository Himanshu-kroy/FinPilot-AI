# ─────────────────────────────────────────────────────────────────────────────
# FinPilot AI — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# NOTE: The live IBM Watson Orchestrate credentials are currently embedded
# directly in src/components/watson/WatsonChat.jsx.
# Move them here and read via import.meta.env if you need per-environment
# configs (dev / staging / production).
# ─────────────────────────────────────────────────────────────────────────────

# ── IBM Watson Orchestrate Embedded Agent ─────────────────────────────────────
# Found in: IBM Watson Orchestrate → Agent settings → Channels → Embed

# The concatenated orchestration ID (tenantId_instanceId)
VITE_WXO_ORCHESTRATION_ID=3f406d595f364fb4bf136b9fc22eab21_fc9579c7-a0d2-46f3-a567-0e2b611b2aee

# Base URL for the wxO region
VITE_WXO_HOST_URL=https://us-south.watson-orchestrate.cloud.ibm.com

# The IBM Cloud Resource Name for this instance
VITE_WXO_CRN=crn:v1:bluemix:public:watsonx-orchestrate:us-south:a/3f406d595f364fb4bf136b9fc22eab21:fc9579c7-a0d2-46f3-a567-0e2b611b2aee::

# The agent UUID from Watson Orchestrate
VITE_WXO_AGENT_ID=92949718-3821-47c4-81bf-8e96c2627bdd

# The deployed environment ID
VITE_WXO_AGENT_ENVIRONMENT_ID=45391817-527a-4933-86f2-acfde95f9711

# ── Application ───────────────────────────────────────────────────────────────

# Base URL for production deployment (used for SEO meta tags)
VITE_APP_URL=https://finpilot.ai
